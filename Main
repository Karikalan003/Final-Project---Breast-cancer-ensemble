for (name, res), color in zip(results.items(), colors_roc):
    if res['y_prob'] is not None:
        fpr, tpr, _ = roc_curve(y_test, res['y_prob'])
        plt.plot(fpr, tpr, label=f"{name} (AUC={res['AUC-ROC']:.1f}%)",
                 color=color, linewidth=1.8)

plt.plot([0, 1], [0, 1], 'k--', linewidth=1, label='Random Classifier (AUC=50%)')
plt.title('ROC Curves — All Models', fontsize=15, fontweight='bold')
plt.xlabel('False Positive Rate (1 - Specificity)', fontsize=12)
plt.ylabel('True Positive Rate (Sensitivity)', fontsize=12)
plt.legend(loc='lower right', fontsize=9)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('roc_curves.png', dpi=150, bbox_inches='tight')
plt.show()

# Confusion Matrix — Best Model
best_model_name = summary['AUC-ROC'].idxmax()
best_cm = results[best_model_name]['cm']

fig, axes = plt.subplots(1, 2, figsize=(14, 5))

# Raw counts
disp = ConfusionMatrixDisplay(confusion_matrix=best_cm,
                               display_labels=['Benign (0)', 'Malignant (1)'])
disp.plot(ax=axes[0], colorbar=False, cmap='Blues')
axes[0].set_title(f'Confusion Matrix: {best_model_name}\n(Counts)', fontsize=12, fontweight='bold')

# Normalized
cm_norm = best_cm.astype('float') / best_cm.sum(axis=1)[:, np.newaxis]
disp2 = ConfusionMatrixDisplay(confusion_matrix=cm_norm,
                                display_labels=['Benign (0)', 'Malignant (1)'])
disp2.plot(ax=axes[1], colorbar=False, cmap='Oranges')
axes[1].set_title(f'Confusion Matrix: {best_model_name}\n(Normalized)', fontsize=12, fontweight='bold')

plt.tight_layout()
plt.savefig('confusion_matrix.png', dpi=150, bbox_inches='tight')
plt.show()

tn, fp, fn, tp = best_cm.ravel()
print(f"\nConfusion Matrix Details ({best_model_name}):")
print(f"  True  Negatives (Benign correctly identified)  : {tn}")
print(f"  False Positives (Benign wrongly flagged cancer): {fp}  <-- Type I Error")
print(f"  False Negatives (Cancer missed!)               : {fn}  <-- Type II Error (Most Critical!)")
print(f"  True  Positives (Cancer correctly detected)    : {tp}")


# Classification Report — Best Model
y_pred_best = results[best_model_name]['y_pred']
print(f"Classification Report: {best_model_name}")
print("=" * 55)
print(classification_report(y_test, y_pred_best, target_names=['Benign', 'Malignant']))

# Sensitivity vs Specificity Scatter Plot
# In cancer detection: HIGH SENSITIVITY is the most critical requirement.
# Missed cancers (False Negatives) are far more dangerous than false alarms.

fig, ax = plt.subplots(figsize=(11, 8))
for name, res in results.items():
    ax.scatter(res['Specificity'], res['Sensitivity'], s=200, zorder=5)
    ax.annotate(name, (res['Specificity'], res['Sensitivity']),
                textcoords='offset points', xytext=(6, 4), fontsize=8)

ax.set_xlabel('Specificity (%) — Correct Benign Identification', fontsize=12)
ax.set_ylabel('Sensitivity (%) — Correct Malignant Detection', fontsize=12)
ax.set_title('Sensitivity vs Specificity\n(Ideal model: Top-Right Corner)', fontsize=13, fontweight='bold')
ax.axvline(90, color='orange', linestyle='--', alpha=0.5, label='90% Specificity')
ax.axhline(90, color='red', linestyle='--', alpha=0.5, label='90% Sensitivity (critical threshold)')
ax.legend(fontsize=9)
ax.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('sensitivity_specificity.png', dpi=150, bbox_inches='tight')
plt.show()

# Save model comparison table
summary.to_csv('model_performance_summary.csv')
print("Saved: model_performance_summary.csv")


Export Results
# Save predictions from best model
pred_df = X_test.copy()
pred_df['Actual']          = y_test.values
pred_df['Predicted']       = results[best_model_name]['y_pred']
pred_df['Actual_Label']    = pred_df['Actual'].map({0: 'Benign', 1: 'Malignant'})
pred_df['Predicted_Label'] = pred_df['Predicted'].map({0: 'Benign', 1: 'Malignant'})
pred_df['Correct']         = (pred_df['Actual'] == pred_df['Predicted'])
pred_df.to_csv('predictions_best_model.csv', index=False)
print(f"Saved: predictions_best_model.csv  [Best model: {best_model_name}]")

Final Report
print("=" * 65)
print("     BREAST CANCER PREDICTION — FINAL SUMMARY REPORT")
print("=" * 65)
print(f"  Dataset               : {len(df)} patients, {X.shape[1]} features")
print(f"  Target Classes        : Malignant (1=Cancer) | Benign (0=No Cancer)")
print(f"  Train / Test Split    : 80% / 20% (stratified)")
print(f"  Total Models Tested   : {len(results)}")
print(f"  Best Model (AUC-ROC)  : {summary['AUC-ROC'].idxmax()} — {summary['AUC-ROC'].max():.2f}%")
print(f"  Best Sensitivity      : {summary['Sensitivity'].max():.2f}% ({summary['Sensitivity'].idxmax()})")
print(f"  Best Specificity      : {summary['Specificity'].max():.2f}% ({summary['Specificity'].idxmax()})")
print("=" * 65)
print("\nKey Insights:")
print("  1. SENSITIVITY is the most critical metric in cancer detection.")
print("     A False Negative (missed cancer) is far more dangerous")
print("     than a False Positive (unnecessary biopsy).")
print("  2. AUC-ROC > 95% means the model is an excellent discriminator.")
print("  3. Boosting methods (AdaBoost, Gradient Boosting, XGBoost)")
print("     generally outperform bagging on structured medical data.")
print("  4. SVM (tuned) is highly competitive on high-dimensional")
print("     normalized medical features.")
print("  5. Most predictive features: concave points, perimeter,")
print("     area, and radius — especially the 'worst' values.")
