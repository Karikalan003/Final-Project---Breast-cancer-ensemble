Voting Classifier
# Hard Voting
hard_voting = VotingClassifier(
    estimators=[
        ('lr', LogisticRegression(max_iter=1000, random_state=42)),
        ('rf', RandomForestClassifier(n_estimators=100, random_state=42)),
        ('gb', GradientBoostingClassifier(n_estimators=100, random_state=42))
    ],
    voting='hard'
)
evaluate_model('Voting (Hard)', hard_voting, X_train_sc, y_train, X_test_sc, y_test)

# Soft Voting
soft_voting = VotingClassifier(
    estimators=[
        ('lr', LogisticRegression(max_iter=1000, random_state=42)),
        ('rf', RandomForestClassifier(n_estimators=100, random_state=42)),
        ('gb', GradientBoostingClassifier(n_estimators=100, random_state=42))
    ],
    voting='soft'
)
evaluate_model('Voting (Soft)', soft_voting, X_train_sc, y_train, X_test_sc, y_test)

Stacking Classifier
stacking = StackingClassifier(
    estimators=[
        ('dt',  DecisionTreeClassifier(max_depth=5, random_state=42)),
        ('knn', KNeighborsClassifier(n_neighbors=5)),
        ('rf',  RandomForestClassifier(n_estimators=100, random_state=42))
    ],
    final_estimator=LogisticRegression(max_iter=1000),
    cv=5,
    n_jobs=-1
)
evaluate_model('Stacking', stacking, X_train_sc, y_train, X_test_sc, y_test)

SVM Classifier
# SVM with Default Parameters
# SVM finds the hyperplane that maximizes the margin between classes
evaluate_model('SVM (Default)',
               SVC(kernel='rbf', probability=True, random_state=42),
               X_train_sc, y_train, X_test_sc, y_test)

# Compare SVM Kernels
kernels = ['linear', 'rbf', 'poly', 'sigmoid']
kernel_results = {}

print("SVM Kernel Comparison:\n")
print(f"{'Kernel':<10} {'Accuracy':>10} {'AUC-ROC':>10} {'Sensitivity':>12} {'Specificity':>12}")
print("-" * 58)

for kernel in kernels:
    svm = SVC(kernel=kernel, probability=True, random_state=42)
    svm.fit(X_train_sc, y_train)
    y_pred = svm.predict(X_test_sc)
    y_prob = svm.predict_proba(X_test_sc)[:, 1]
    cm_k = confusion_matrix(y_test, y_pred)
    tn_k, fp_k, fn_k, tp_k = cm_k.ravel()
    acc  = accuracy_score(y_test, y_pred) * 100
    auc  = roc_auc_score(y_test, y_prob) * 100
    sens = recall_score(y_test, y_pred) * 100
    spec = tn_k / (tn_k + fp_k) * 100
    kernel_results[kernel] = {'Accuracy': acc, 'AUC': auc, 'Sensitivity': sens, 'Specificity': spec}
    print(f"{kernel:<10} {acc:>9.2f}% {auc:>9.2f}% {sens:>11.2f}% {spec:>11.2f}%")

Hyperparameter Tuning — SVM with GridSearchCV
param_grid = {
    'C'     : [0.1, 1, 10, 100],
    'gamma' : ['scale', 'auto', 0.001, 0.01],
    'kernel': ['rbf', 'linear']
}

cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)

grid_search = GridSearchCV(
    SVC(probability=True, random_state=42),
    param_grid=param_grid,
    cv=cv,
    scoring='roc_auc',  # Optimizing AUC is better than accuracy for medical data
    n_jobs=-1,
    verbose=1
)

print("Running GridSearchCV (this may take 1-2 minutes)...")
grid_search.fit(X_train_sc, y_train)

print(f"\nBest Parameters : {grid_search.best_params_}")
print(f"Best CV AUC     : {grid_search.best_score_*100:.2f}%")

# Evaluate best SVM
best_svm = grid_search.best_estimator_
evaluate_model('SVM (Tuned)', best_svm, X_train_sc, y_train, X_test_sc, y_test)
# Cross-Validation on Tuned SVM
cv_scores = cross_val_score(best_svm, X_train_sc, y_train, cv=cv, scoring='roc_auc')
print(f"5-Fold Cross-Validation AUC (Tuned SVM):")
for i, s in enumerate(cv_scores, 1):
    print(f"  Fold {i}: {s*100:.2f}%")
print(f"  Mean : {cv_scores.mean()*100:.2f}%")
print(f"  Std  : +/-{cv_scores.std()*100:.2f}%")


Final Model Comparison and Visualizations
# Summary Table
metrics_keys = ['Accuracy', 'Precision', 'Sensitivity', 'Specificity', 'F1 Score', 'AUC-ROC']
summary = pd.DataFrame(
    {name: {k: v for k, v in res.items() if k in metrics_keys}
     for name, res in results.items()}
).T

print("MODEL PERFORMANCE SUMMARY (all values in %)")
